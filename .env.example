VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Google Gemini API key for Chatbot Assistant (optional system default key)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Toggle Voice-to-Text entry STT and Text-to-Speech response reading TTS (defaults to true if omitted)
VITE_ENABLE_STT=true
VITE_ENABLE_TTS=true

# Optional External API Keys (Leave blank to use free native browser local Speech APIs)
# VITE_STT_API_KEY=your_openai_whisper_key_here
# VITE_TTS_API_KEY=your_elevenlabs_or_murf_key_here
